# Dockerfile.mcp - Minimal MCP Server image
#
# Build:
#   docker build -f Dockerfile.mcp -t openclaw/mcp-server:latest .
#
# Run:
#   docker run --rm openclaw/mcp-server:latest
#   # Or with environment:
#   docker run --rm -e OPENCLAW_API_KEY=sk-... openclaw/mcp-server:latest

# ---- Build stage ----
FROM rust:1.75-slim AS builder

WORKDIR /usr/src/openclaw-rs

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

RUN cargo build --release -p mcp-server

# ---- Runtime stage ----
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /usr/src/openclaw-rs/target/release/mcp-server .

# Run as non-root
RUN useradd -m -u 1000 openclaw && chown -R openclaw:openclaw /app
USER openclaw

ENTRYPOINT ["./mcp-server"]
