# Dockerfile.dev - Development environment
# 
# Usage:
#   docker build -f Dockerfile.dev -t openclaw-dev .
#   docker compose run --rm dev

FROM rust:1.75-slim

# Install development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
    ca-certificates \
    curl \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Install Rust tools
RUN cargo install cargo-watch cargo-expand cargo-clippy && rustup component add rustfmt clippy

WORKDIR /workspace

# Default command
CMD ["sleep", "infinity"]
